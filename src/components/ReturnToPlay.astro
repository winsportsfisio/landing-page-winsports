---
import { site } from '../data/site';

const pillars = [
  {
    title: 'Retorno orientado',
    description: 'Protocolos baseados em evidências científicas.',
  },
  {
    title: 'Testes funcionais',
    description: 'Avaliações objetivas de força, estabilidade e movimento.',
  },
  {
    title: 'Progressão controlada',
    description: 'Aumento gradual de carga respeitando a cicatrização tecidual.',
  },
  {
    title: 'Prevenção de lesões',
    description: 'Correção de padrões de movimento que podem gerar novas lesões.',
  },
];
---

<section id="return-to-play" class="section relative overflow-hidden bg-navy text-white" aria-labelledby="rtp-title">
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(6,182,212,0.18),transparent_60%)]"
  ></div>
  <div class="container relative mx-auto">
    <header class="reveal max-w-2xl">
      <span class="mb-3 inline-block text-xs font-bold uppercase tracking-[0.2em] text-cyan-400">
        Return to Play
      </span>
      <h2 id="rtp-title" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        Volte ao esporte com confiança
      </h2>
      <p class="mt-4 text-base md:text-lg text-slate-300">
        O conceito de Return to Play (Retorno ao Esporte) é o núcleo da nossa prática.
        Não basta tratar a lesão — é preciso preparar o corpo para as demandas específicas
        da sua modalidade antes do retorno.
      </p>
    </header>

    <ul class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {
        pillars.map((p, idx) => (
          <li
            class="reveal rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur transition hover:border-cyan-400/40 hover:bg-white/10 hover:-translate-y-1"
            style={`--reveal-delay: ${idx * 80}ms;`}
          >
            <div class="mb-5 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-cyan-500/20 text-sm font-bold text-cyan-400">
              {String(idx + 1).padStart(2, '0')}
            </div>
            <h3 class="text-lg font-semibold text-white">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">{p.description}</p>
          </li>
        ))
      }
    </ul>

    <!-- Prova social real: 5,0 no Google, sem schema aggregateRating -->
    <div class="reveal mt-14 flex flex-col items-start gap-4 rounded-2xl border border-cyan-400/30 bg-cyan-500/5 p-6 md:flex-row md:items-center md:justify-between">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-1 text-cyan-400" aria-hidden="true">
          {
            [0, 1, 2, 3, 4].map(() => (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            ))
          }
        </div>
        <div>
          <p class="text-base font-semibold text-white">
            <span class="sr-only">Nota: </span>5,0 no Google
          </p>
          <p class="text-sm text-slate-300">7 avaliações de pacientes reais</p>
        </div>
      </div>
      <a
        href={site.gbpMapsUrl}
        target="_blank"
        rel="noopener"
        class="btn-secondary !border-cyan-400/40 !bg-cyan-500/10 !text-cyan-300 hover:!bg-cyan-500/20"
        aria-label="Ver avaliações da WIN SPORTS no Google Maps"
      >
        Ver no Google Maps
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>
