---
import { site } from '../data/site';
---

<section
  class="relative isolate overflow-hidden bg-navy text-white"
  aria-labelledby="hero-title"
>
  <!-- Background image (preloaded no BaseLayout) -->
  <img
    src="/hero-placeholder.svg"
    alt=""
    aria-hidden="true"
    width="1920"
    height="1080"
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover opacity-90"
  />

  <!-- Overlay de leitura (gradiente horizontal + vertical inferior) -->
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-r from-navy via-navy/80 to-navy/40"
  ></div>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-t from-navy/95 via-transparent to-transparent"
  ></div>

  <!-- Orbs de glow ciano (animate-pulse) -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-20 right-[10%] h-96 w-96 rounded-full bg-cyan-500/10 blur-3xl animate-pulse"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute bottom-0 left-[5%] h-80 w-80 rounded-full bg-royal/20 blur-3xl animate-pulse"
    style="animation-delay: 1.5s;"
  ></div>

  <div
    class="container relative mx-auto flex min-h-[100vh] flex-col justify-center py-28 md:py-32"
  >
    <span
      class="reveal inline-flex w-fit items-center gap-2 rounded-full border border-cyan-400/30 bg-cyan-500/10 px-4 py-1.5 text-xs font-medium text-cyan-300 backdrop-blur"
    >
      <span aria-hidden="true" class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-cyan-400"></span>
      </span>
      Fisioterapia Esportiva · Florianópolis
    </span>

    <!-- Light streak ancorado ao badge: sempre 20px abaixo, em qualquer viewport.
         Wrapper .hero-streak-row tem height: 0, então não empurra o H1.
         O streak filho escapa do padding do container e cobre toda a seção. -->
    <div aria-hidden="true" class="hero-streak-row mt-5">
      <div class="light-streak"></div>
    </div>

    <h1
      id="hero-title"
      class="reveal mt-6 max-w-3xl text-4xl font-bold leading-[1.05] tracking-tight text-white md:text-6xl lg:text-7xl"
      style="--reveal-delay: 80ms;"
    >
      Do diagnóstico ao<br />
      <span class="gradient-text">retorno ao jogo.</span>
    </h1>

    <p
      class="reveal mt-6 max-w-2xl text-base text-slate-300 md:text-lg"
      style="--reveal-delay: 160ms;"
    >
      Fisioterapia esportiva especializada em Florianópolis, Estreito. Reabilitação,
      Recuperação e Return to Play para atletas e pessoas ativas da Grande Florianópolis.
    </p>

    <!-- Light streak ancorado ao subhead: sempre 24px abaixo do parágrafo. -->
    <div aria-hidden="true" class="hero-streak-row mt-6">
      <div class="light-streak light-streak--delay-1"></div>
    </div>

    <div
      class="reveal mt-10 flex flex-col gap-3 sm:flex-row sm:items-center"
      style="--reveal-delay: 240ms;"
    >
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener"
        aria-label="Agendar avaliação via WhatsApp"
        class="btn-primary animate-pulse-glow group"
      >
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        Agendar avaliação
        <svg
          aria-hidden="true"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:translate-x-1"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
      <a
        href="#sobre"
        class="btn-secondary"
        aria-label="Ir para a seção Sobre a clínica"
      >
        Conheça nosso trabalho
      </a>
    </div>

    <dl
      class="reveal mt-16 grid grid-cols-1 gap-6 border-t border-white/10 pt-8 text-center text-sm sm:grid-cols-3 sm:gap-10 sm:text-left md:gap-14"
      style="--reveal-delay: 320ms;"
    >
      <div>
        <dt class="text-cyan-400 font-semibold">Avaliação</dt>
        <dd class="mt-1 text-slate-300">Detalhada e individual</dd>
      </div>
      <div class="sm:border-l sm:border-white/10 sm:pl-6 md:pl-10">
        <dt class="text-cyan-400 font-semibold">Return to Play</dt>
        <dd class="mt-1 text-slate-300">Baseado em critérios</dd>
      </div>
      <div class="sm:border-l sm:border-white/10 sm:pl-6 md:pl-10">
        <dt class="text-cyan-400 font-semibold">Reabilitação</dt>
        <dd class="mt-1 text-slate-300">Baseado em evidências</dd>
      </div>
    </dl>
  </div>

  <!-- Scroll indicator (mouse com dot animado). Classe .scroll-indicator
       permite ocultá-lo totalmente em prefers-reduced-motion. -->
  <a
    href="#como-trabalhamos"
    aria-label="Rolar para a próxima seção"
    class="scroll-indicator group absolute bottom-6 left-1/2 hidden -translate-x-1/2 md:block"
  >
    <span class="flex h-10 w-6 justify-center rounded-full border-2 border-white/30 pt-2 transition group-hover:border-cyan-400">
      <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-cyan-400 animate-scroll-dot"></span>
    </span>
  </a>
</section>
