---
import { site } from '../data/site';
---

<section
  class="relative flex min-h-[50vh] items-center overflow-hidden bg-navy py-24 text-white md:min-h-[60vh] md:py-32"
  aria-labelledby="final-cta-title"
>
  <!-- Background layers decorativos. SUBSTITUIR DEPOIS: trocar por foto/arte
       de fundo real (paciente em sessão, clínica, etc.) quando disponível. -->
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(6,182,212,0.22),transparent_55%)]"
  ></div>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(29,78,216,0.22),transparent_55%)]"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-32 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-cyan-500/10 blur-3xl animate-pulse"
  ></div>

  <div class="container relative mx-auto flex flex-col items-center text-center">
    <span class="reveal inline-block text-xs font-bold uppercase tracking-[0.2em] text-cyan-400">
      Comece sua recuperação
    </span>
    <h2
      id="final-cta-title"
      class="reveal mt-4 max-w-3xl text-4xl font-bold leading-tight text-white md:text-5xl lg:text-6xl"
      style="--reveal-delay: 80ms;"
    >
      Pronto para voltar ao jogo?
    </h2>
    <p
      class="reveal mt-6 max-w-2xl text-base text-slate-300 md:text-lg"
      style="--reveal-delay: 160ms;"
    >
      Agende sua avaliação e dê o primeiro passo para uma recuperação segura e eficiente.
      Nossa equipe está pronta para atender você.
    </p>

    <div class="reveal mt-10" style="--reveal-delay: 240ms;">
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener"
        aria-label="Agendar avaliação via WhatsApp"
        class="btn-primary animate-pulse-glow group !px-8 !py-4 !text-base md:!text-lg"
      >
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        Agendar avaliação
        <svg
          aria-hidden="true"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:translate-x-1"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    </div>

    <ul
      class="reveal mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-sm text-slate-300"
      style="--reveal-delay: 320ms;"
    >
      <li class="flex items-center gap-2">
        <span class="grid h-8 w-8 place-items-center rounded-full bg-cyan-500/15 text-cyan-400" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </span>
        Resposta em até 24h
      </li>
      <li class="flex items-center gap-2">
        <span class="grid h-8 w-8 place-items-center rounded-full bg-cyan-500/15 text-cyan-400" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </span>
        Atendimento direto pelo WhatsApp
      </li>
      <li class="flex items-center gap-2">
        <span class="grid h-8 w-8 place-items-center rounded-full bg-cyan-500/15 text-cyan-400" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </span>
        Balneário · Estreito · Florianópolis
      </li>
    </ul>
  </div>
</section>
