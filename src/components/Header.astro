---
import { site } from '../data/site';

interface Props {
  variant?: 'transparent-over-hero' | 'solid';
}

const { variant = 'solid' } = Astro.props;

const navLinks = [
  { href: '#sobre', label: 'Sobre' },
  { href: '#como-trabalhamos', label: 'Como trabalhamos' },
  { href: '#especialidades', label: 'Especialidades' },
  { href: '#depoimentos', label: 'Depoimentos' },
  { href: '#faq', label: 'FAQ' },
];
---

<header
  id="site-header"
  data-variant={variant}
  class="site-header fixed inset-x-0 top-0 z-50 transition-[background-color,backdrop-filter,border-color,box-shadow] duration-300"
>
  <div class="container mx-auto flex h-16 items-center justify-between md:h-20">
    <a href="/" aria-label="WIN SPORTS — Início" class="flex items-center">
      <img
        src="/logo.png"
        alt="WIN SPORTS — Fisioterapia Esportiva"
        width="1200"
        height="800"
        decoding="async"
        class="h-24 w-auto md:h-30 transition duration-300"
      />
    </a>

    <nav aria-label="Principal" class="hidden items-center gap-8 lg:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="group relative text-sm font-medium text-slate-200 transition-colors hover:text-white"
          >
            {link.label}
            <span
              aria-hidden="true"
              class="pointer-events-none absolute left-0 -bottom-1 h-0.5 w-0 rounded-full bg-cyan-400 transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:block">
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener"
        aria-label="Agendar avaliação via WhatsApp"
        class="btn-primary !px-5 !py-2.5"
      >
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        Agendar
      </a>
    </div>

    <button
      id="mobile-menu-toggle"
      type="button"
      class="lg:hidden grid h-10 w-10 place-items-center rounded-lg text-white transition hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menu de navegação"
    >
      <svg class="menu-icon-open" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
      <svg class="menu-icon-close hidden" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-navy/95 backdrop-blur lg:hidden"
    aria-label="Menu mobile"
  >
    <nav aria-label="Principal mobile" class="container mx-auto flex flex-col gap-1 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-lg px-3 py-3 text-base font-medium text-slate-200 transition hover:bg-white/5 hover:text-white"
            data-mobile-link
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={site.contact.whatsappUrl}
        target="_blank"
        rel="noopener"
        aria-label="Agendar avaliação via WhatsApp"
        class="btn-primary mt-2 w-full"
        data-mobile-link
      >
        Agendar avaliação
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const btn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');

    // Scroll state: adiciona .is-scrolled quando passa de 20px. Usado pelo CSS
    // para transicionar header transparente -> sólido sobre o hero.
    if (header) {
      const onScroll = () => {
        const scrolled = window.scrollY > 20;
        header.classList.toggle('is-scrolled', scrolled);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    if (!btn || !menu) return;
    const iconOpen = btn.querySelector('.menu-icon-open');
    const iconClose = btn.querySelector('.menu-icon-close');

    function setOpen(open) {
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Fechar menu de navegação' : 'Abrir menu de navegação');
      menu.classList.toggle('hidden', !open);
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
    }

    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });

    menu.querySelectorAll('[data-mobile-link]').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });
  })();
</script>
